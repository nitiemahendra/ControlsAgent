# Gemini API key — must start with AIzaSy...
# Create at: https://console.cloud.google.com/apis/credentials
# Enable "Gemini API" (generativelanguage.googleapis.com) in the same project.
# Without this key the agent uses a default plan and check-generated rationale.
GEMINI_API_KEY=your_AIzaSy_key_here

